-- ==================== SYSTEM DRAGGING BARU ====================
local function buatDraggable(objekSentuh, objekGerak)
    local dragging, dragInput, dragStart, startPos

    objekSentuh.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = objekGerak.Position
            if input.UserInputType == Enum.UserInputType.Touch then
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end
    end)
    objekSentuh.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            objekGerak.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    objekSentuh.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
end

-- ==================== STAFF / OWNER DETECTOR (ANTI-BAN SYSTEM) ====================
local staffList = {
    [8] = "Staff Angel",
    [10] = "Staff Maarz",
