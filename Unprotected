local function gantiTarget()
    local semuaPlayer = Players:GetPlayers()
    if #semuaPlayer == 0 then return end
    if targetIndex > #semuaPlayer then targetIndex = 1 end
    if targetIndex < 1 then targetIndex = #semuaPlayer end
    targetPlayer = semuaPlayer[targetIndex]
    if targetPlayer then
        TargetLabel.Text = "Target: " .. targetPlayer.Name
        updateAvatarPreview()
    end
end

PrevBtn.MouseButton1Click:Connect(function() targetIndex = targetIndex - 1; gantiTarget() end)
NextBtn.MouseButton1Click:Connect(function() targetIndex = targetIndex + 1; gantiTarget() end)
Players.PlayerAdded:Connect(gantiTarget); Players.PlayerRemoving:Connect(gantiTarget)
