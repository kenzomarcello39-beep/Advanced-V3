}

local function periksaStaff(player)
    if staffList[player.UserId] then
        -- Mainkan Bunyi Penggera Sangat Kuat
        SFX_Alarm:Play()
        
        -- Tunggu 1.5 saat agar pengguna dengar amaran sebelum dikick
        task.wait(1.5)
        
        -- Kick Player demi keselamatan (Alasan dalam Bahasa Inggeris)
        LocalPlayer:Kick("\n⚠️ SECURITY ALERT ⚠️\n\n" .. staffList[player.UserId] .. " has joined the server!\n\nAuto-disconnect initiated to protect your account from a potential ban.")
    end
end

Players.PlayerAdded:Connect(periksaStaff)
for _, p in pairs(Players:GetPlayers()) do
    periksaStaff(p) -- Periksa jika mereka sudah ada dalam pelayan ketika script diinject
end

